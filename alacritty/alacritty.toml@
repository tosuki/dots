import = ["/home/drew/.config/alacritty/catppuccin/catppuccin-mocha.toml"]
live_config_reload = true
window.opacity = 1.0

[colors.normal]
black   = '#709080'
red     = '#DCA3A3'
green   = '#C3BF9F'
yellow  = '#F0DFAF'
blue    = '#94BFF3'
magenta = '#EC93D3'
cyan    = '#93E0E3'
white   = '#FFFFFF'

# Bright colors
[colors.bright]
black   = '#709080'
red     = '#DCA3A3'
green   = '#C3BF9F'
yellow  = '#F0DFAF'
blue    = '#94BFF3'
magenta = '#EC93D3'
cyan    = '#93E0E3'
white   = '#FFFFFF'

[colors.hints.end]
background = "#ffffff"
foreground = "#1E1E2E"

[colors.hints.start]
background = "#cdcd00"
foreground = "#1E1E2E"

[colors.primary]
background="#444444"
#background="#000000"
foreground="#FFFFFF"

[colors.vi_mode_cursor]
cursor = "#B4BEFE"
text = "#1E1E2E"

[font]
size = 9

[font.normal]
family = "Iosevka"
style = "Regular"

[[keyboard.bindings]]
action = "SpawnNewInstance"
key = "Return"
mods = "Control|Shift"


[window.padding]
x = 0
y = 0

[cursor]
# Cursor style options: "Block", "Underline", or "Beam".
style = "Block"

